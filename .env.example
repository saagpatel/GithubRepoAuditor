# GitHub Repo Auditor — environment configuration
# Copy to .env and fill in values before running

# Required: GitHub Personal Access Token (needs repo, read:org scopes)
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Optional: Anthropic API key for AI narrative generation (--ai-narrative flag)
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: Notion integration token for Notion sync (--notion flag)
# Get one at: https://www.notion.so/my-integrations
NOTION_TOKEN=
