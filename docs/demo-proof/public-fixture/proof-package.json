        "status": "passed"
      },
      {
        "name": "visual capture from Portfolio Command Center",
        "status": "passed"
      }
    ],
    "missing_receipts": [],
    "known_gaps": [
      "The fixture date is intentionally static, so screenshots show the app stale-data banner when viewed after the fixture date."
    ]
  },
